// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model Farmer {
  farmer_id     Int @id @default(autoincrement())
  full_name     String
  phone_number  String @unique
  region        String?
  district      String?

  farms Farm[]

  created_at DateTime @default(now())
}

model Crop {
  crop_id    Int    @id @default(autoincrement())
  crop_name  String

  farms      Farm[]
}

model Farm {
  farm_id      Int @id @default(autoincrement())

  farmer_id    Int
  crop_id      Int

  farm_size    Float?

  farmer Farmer @relation(fields: [farmer_id], references: [farmer_id])

  crop Crop @relation(fields: [crop_id], references: [crop_id])

  advisory_logs AdvisoryLog[]
}

model ExpertRule {
  rule_id          String @id // niweze kutumia Natural Key Hash
  
  crop_name        String

  symptom_keyword  String // test mode ya kumentain id kuwa primary key inayo eleweka

  diagnosis        String

  recommendation   String

  @@index([crop_name])
}

model AdvisoryLog {

  log_id Int @id @default(autoincrement())

  farm_id Int

  rawSymptomQuery String   @db.Text @default("") // Inatunza sentensi nzima aliyoandika na mkulima

  reported_symptom String

  diagnosis String

  recommendation String

  source String

  created_at DateTime @default(now())

  farm Farm @relation(fields: [farm_id], references: [farm_id])
}

model FileMeta {
  id        Int      @id @default(autoincrement())
  fileName  String   @unique  // inasom "expert_rules.xlsx"
  lastMd5   String            // Itatunza alama ya vidole ya faili (Hash)
  updatedAt DateTime @updatedAt
}